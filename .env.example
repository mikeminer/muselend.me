# Public application configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532
NEXT_PUBLIC_MAINNET_ENABLED=false
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Sepolia role addresses used by the Foundry deployment script. No key material.
TESTNET_ADMIN=
TESTNET_TIMELOCK_PROPOSER=
TESTNET_PAUSE_GUARDIAN=

# Read-only RPC endpoints. Use provider dashboards or local secrets; never commit keys.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Optional cache/indexing services. Clients must initialize lazily.
DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Authentication/session secrets (generate locally per environment)
SESSION_SECRET=
INDEXER_SYNC_SECRET=

# Deployment addresses are populated only after verified Base Sepolia deployment.
NEXT_PUBLIC_POSITION_MANAGER_ADDRESS=
NEXT_PUBLIC_SENIOR_VAULT_ADDRESS=
NEXT_PUBLIC_HEDGE_EPOCH_VAULT_ADDRESS=
NEXT_PUBLIC_CREATOR_TOKEN_VALIDATOR_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

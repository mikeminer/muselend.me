# Public application configuration
NEXT_PUBLIC_APP_URL=https://muselend.me
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532
NEXT_PUBLIC_MAINNET_ENABLED=false
MAINNET_ENABLED=false
MAINTENANCE_MODE=false
GEOFENCING_ENABLED=false
ALLOWLIST_ENABLED=false
KYC_ADAPTER_ENABLED=false
JURISDICTION_RESTRICTIONS_ENABLED=false
MAX_RETAIL_EXPOSURE_ENABLED=false
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Sepolia role addresses used by the Foundry deployment script. No key material.
TESTNET_ADMIN=0xFdC4232d77A3A2Bf69D520A2069Bb8ee5Edadef1
TESTNET_TIMELOCK_PROPOSER=0xFdC4232d77A3A2Bf69D520A2069Bb8ee5Edadef1
TESTNET_PAUSE_GUARDIAN=0x3074a77986546b16Be4eED2ADB85A74753552F42

# Read-only RPC endpoints. Use provider dashboards or local secrets; never commit keys.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_MAINNET_FALLBACK_RPC_URL=https://base-rpc.publicnode.com
ZORA_API_KEY=

# Server-only signer for Base-mainnet balance attestations. Use a dedicated,
# zero-funded key and never expose it through a NEXT_PUBLIC variable.
TESTNET_CLAIM_ATTESTER=0x9324018e1F22b69612d2B783b8Bb108bfE0aCEAA
TESTNET_CLAIM_ATTESTER_PRIVATE_KEY=

# Optional cache/indexing services. Clients must initialize lazily.
DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Authentication/session secrets (generate locally per environment)
SESSION_SECRET=
INDEXER_SYNC_SECRET=
